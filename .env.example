# PersonalOS System Environment Configurations

# ----------------- DB SETTINGS -----------------
# SQLite configuration (Local Dev Default)
DATABASE_URL=sqlite:///./personalos.db

# PostgreSQL configuration (Production Render/Railway Setup example)
# DATABASE_URL=postgresql://user:password@host:port/dbname

# ----------------- TWILIO WHATSAPP API -----------------
# Your Twilio Account SID
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here

# Your Twilio Auth Token
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here

# Your Twilio WhatsApp Sandbox Number (default: +14155238886)
TWILIO_WHATSAPP_FROM=+14155238886

# ----------------- GEMINI AI API -----------------
# Gemini API Key (e.g. from Google AI Studio) for study timetable generation and coaching reflection boosts
GEMINI_API_KEY=your_gemini_key_here
